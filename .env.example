# Copy this file to .env (same directory) and set a real password.
# .env is gitignored — never commit real credentials.
POSTGRES_USER=genealogy
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=genealogy_workspace
PGPORT=5432

# Docker container name. The default is fine for a single install. To run
# several independent workspace installs on one machine, give each its own
# unique CONTAINER_NAME *and* PGPORT (the fixed defaults would otherwise
# collide on the container name and host port).
CONTAINER_NAME=genealogy-postgres
